# .env.example — VideoScribe
# Copy to .env.local and fill in real values. Never commit .env.local.

# ---- Gemini (server-only) ----
GEMINI_API_KEY=
GEMINI_TRANSCRIPTION_MODEL=gemini-3-flash-preview
GEMINI_ANALYSIS_MODEL=gemini-3.1-pro-preview

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=VideoScribe
